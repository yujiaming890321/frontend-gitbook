{
  "name": "mcp-gitbook-server",
  "version": "1.0.0",
  "description": "MCP server for browsing and searching gitbook documentation. Provides tools, resources, and prompt templates.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-gitbook-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "documentation",
    "gitbook",
    "claude",
    "ai-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "glob": "^11.0.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.3"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  }
}
